CREATE TABLE Precos (
    id_preco INT AUTO_INCREMENT PRIMARY KEY,
    id_modelo INT REFERENCES Modelos(id_modelo),
    valor DECIMAL(10, 2) NOT NULL,
    moeda VARCHAR(100)
);

CREATE TABLE Pecas (
    id_peca INT AUTO_INCREMENT PRIMARY KEY,
    codigo_peca VARCHAR(50) UNIQUE,
    nome_peca VARCHAR(100) NOT NULL,
    categoria VARCHAR(50), -- ex: Motor, Chassi, Elétrica
    quantidade_estoque INT DEFAULT 0,
    custo_unitario DECIMAL(10, 2)
);

CREATE TABLE Funcionarios (
    id_funcionario INT AUTO_INCREMENT PRIMARY KEY,
    nome_completo VARCHAR(150) NOT NULL,
    cargo VARCHAR(100), -- ex: Montador, Gerente de Produção, Diretor
    departamento VARCHAR(100),
    salario DECIMAL(10, 2)
);

CREATE TABLE Usuarios (
    id_usuario INT AUTO_INCREMENT PRIMARY KEY,
    login VARCHAR(50) UNIQUE NOT NULL,
    nivel_acesso VARCHAR(20), -- ex: 'ADMIN', 'OPERADOR', 'VISUALIZADOR'
    ultimo_login TIMESTAMP,
    ativo BOOLEAN DEFAULT TRUE
);

